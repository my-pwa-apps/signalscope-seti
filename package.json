{
  "name": "signalscope-seti",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "SignalScope SETI — a citizen-science PWA inspired by SETI@home.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "pages:dev": "npm run build && wrangler pages dev dist",
    "pages:deploy": "npm run build && wrangler pages deploy dist --project-name signalscope-seti",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-three/fiber": "^8.17.10",
    "clsx": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "three": "^0.169.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "fake-indexeddb": "^6.2.5",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^8.0.13",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.6",
    "wrangler": "^4.91.0"
  }
}
